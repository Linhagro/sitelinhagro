RewriteEngine On

# Home
RewriteCond %{THE_REQUEST} \s/+index\.html[\s?] [NC]
RewriteRule ^index\.html$ / [R=301,L]

# URLs antigas em /paginas/*.html -> /slug
RewriteCond %{THE_REQUEST} \s/+paginas/([^.]+)\.html[\s?] [NC]
RewriteRule ^paginas/([^.]+)\.html$ /$1 [R=301,L]

# URLs antigas em /paginas/slug -> /slug
RewriteCond %{THE_REQUEST} \s/+paginas/([^\s?]+)[\s?] [NC]
RewriteRule ^paginas/([^\s?]+)$ /$1 [R=301,L]

# URL amigável /slug -> /paginas/slug.html
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{DOCUMENT_ROOT}/paginas/$1.html -f
RewriteRule ^([^/]+)$ /paginas/$1.html [L]